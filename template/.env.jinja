# =============================================================================
# Wiki.js Environment Variables
# Copy file ini ke .env dan isi nilainya
# JANGAN commit file .env ke version control
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DB_TYPE=postgres
DB_HOST=db
DB_PORT=5432
DB_NAME={{ db_name }}
DB_USER={{ db_user }}
DB_PASS={{ db_pass }}

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN={{ domain }}

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ={{ tz }}
